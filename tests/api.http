  "name": "Ramesh Kumar",
  "phone": "9876543210",
  "gender": "Male",
  "block": "A",
  "floor_number": "1",
  "company_name": "Test Co",
  "whom_to_meet": "John Doe",
  "reason": "Personal Visit",
  "category": "Guest",
  "vehicle_type": "NA"
}

###
@visitorId = {{createVisitor.response.body.data.id}}

### 23. Create visitor missing phone (expect 422)
POST {{baseUrl}}/admin/visitors/entry
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "No Phone Visitor",
  "block": "A",
  "company_name": "Test Co",
  "reason": "Visit"
}

### 24. Get active visitors
GET {{baseUrl}}/admin/visitors/active
Authorization: Bearer {{adminToken}}

### 25. Checkout visitor
POST {{baseUrl}}/admin/visitors/{{visitorId}}/checkout
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{}

### 26. Checkout visitor twice (expect 422 - already checked out)
POST {{baseUrl}}/admin/visitors/{{visitorId}}/checkout
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{}

