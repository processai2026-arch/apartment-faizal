# ====================================================================
# VISITOR PASSES
# ====================================================================

### 30. List visitor passes
GET {{baseUrl}}/admin/visitor-passes
Authorization: Bearer {{adminToken}}

### 31. Create visitor pass — happy path
# @name createPass
POST {{baseUrl}}/admin/visitor-passes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "pass_type": "One Day",
  "visitor_name": "Delivery Person",
  "visitor_phone": "9876543210",
  "valid_from": "2026-07-09T00:00:00",
  "valid_until": "2026-07-09T23:59:59",
  "max_uses": 1
}

###
@passId = {{createPass.response.body.data.id}}

### 32. Create pass with inverted dates (expect 422 — BUG-05 fix)
POST {{baseUrl}}/admin/visitor-passes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "pass_type": "Temporary",
  "visitor_name": "Bad Date Test",
  "valid_from": "2026-12-01T00:00:00",
  "valid_until": "2026-01-01T00:00:00",
  "max_uses": 1
}

### 33. Scan pass — entry
POST {{baseUrl}}/admin/visitor-passes/{{passId}}/scan
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "action": "entry"
}

### 34. Scan pass after max_uses reached (expect 422 — BUG-03 fix)
POST {{baseUrl}}/admin/visitor-passes/{{passId}}/scan
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "action": "entry"
}

### 35. Create future pass and try to scan immediately (expect 422 — BUG-04 fix)
# @name futurePas
POST {{baseUrl}}/admin/visitor-passes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "pass_type": "Temporary",
  "visitor_name": "Future Visitor",
  "valid_from": "2030-01-01T00:00:00",
  "valid_until": "2030-12-31T23:59:59",
  "max_uses": 5
}

###
@futurePassId = {{futurePas.response.body.data.id}}

POST {{baseUrl}}/admin/visitor-passes/{{futurePassId}}/scan
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "action": "entry"
}

### 36. Get visitor pass dashboard
GET {{baseUrl}}/admin/visitor-passes/dashboard
Authorization: Bearer {{adminToken}}

# ====================================================================
# COMPLAINTS — Tenant
# ====================================================================

### 37. Tenant creates complaint (happy path)
# @name createComplaint
POST {{baseUrl}}/tenant/complaints
Authorization: Bearer {{tenantToken}}
Content-Type: application/json

{
  "category": "Plumbing",
  "subject": "Water leak in bathroom",
  "description": "There is a water leak under the sink",
  "priority": "High"
}

###
@complaintId = {{createComplaint.response.body.data.id}}

### 38. Tenant views own complaint
GET {{baseUrl}}/tenant/complaints/{{complaintId}}
Authorization: Bearer {{tenantToken}}

### 39. Tenant creates complaint missing required fields (expect 422)
POST {{baseUrl}}/tenant/complaints
Authorization: Bearer {{tenantToken}}
Content-Type: application/json

{
  "category": "Electrical"
}

### 40. Admin views all complaints
GET {{baseUrl}}/admin/complaints
Authorization: Bearer {{adminToken}}

### 41. Admin updates complaint status
POST {{baseUrl}}/admin/complaints/{{complaintId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "In Progress",
  "remarks": "Plumber assigned"
}

