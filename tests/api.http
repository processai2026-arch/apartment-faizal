### OfficeGate Production API Tests
### Base URL: https://apartments-demo.kynetropo.com/api
### Run with: REST Client VS Code extension or httpie

@baseUrl = https://apartments-demo.kynetropo.com/api

# ====================================================================
# AUTH — Happy Path
# ====================================================================

### 1. Login as admin (happy path)
# @name adminLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@officegate.com",
  "password": "password"
}

###
@adminToken = {{adminLogin.response.body.data.accessToken}}

### 2. Login as super admin
# @name superLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "superadmin@officegate.local",
  "password": "password"
}

###
@superToken = {{superLogin.response.body.data.accessToken}}

### 3. Login as tenant
# @name tenantLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "tenant@officegate.com",
  "password": "password"
}

###
@tenantToken = {{tenantLogin.response.body.data.accessToken}}

### 4. Login as security
# @name securityLogin
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "security@officegate.com",
  "password": "password"
}

###
@securityToken = {{securityLogin.response.body.data.accessToken}}

# ====================================================================
# AUTH — Sad Paths
# ====================================================================

### 5. Login with wrong password (expect 401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@officegate.com",
  "password": "wrongpassword"
}

### 6. Login with non-existent email (expect 401)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "nobody@example.com",
  "password": "test"
}

### 7. Access protected route without token (expect 401)
GET {{baseUrl}}/admin/dashboard/summary

### 8. Access admin route with tenant token (expect 403)
GET {{baseUrl}}/admin/users
Authorization: Bearer {{tenantToken}}

### 9. Access tenant route with security token (expect 403)
GET {{baseUrl}}/tenant/dashboard
Authorization: Bearer {{securityToken}}

# ====================================================================
# ADMIN DASHBOARD
# ====================================================================

### 10. Get admin dashboard summary
GET {{baseUrl}}/admin/dashboard/summary
Authorization: Bearer {{adminToken}}

### 11. Get analytics summary
GET {{baseUrl}}/admin/analytics/summary
Authorization: Bearer {{adminToken}}

# ====================================================================
# OFFICES / MANAGE USER-TENANT
# ====================================================================

### 12. List all offices
GET {{baseUrl}}/admin/offices
Authorization: Bearer {{adminToken}}

### 13. Create office (happy path)
# @name createOffice
POST {{baseUrl}}/admin/offices
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "block": "A",
  "floor_number": "1",
  "flat_number": "101",
  "company_name": "Test Resident",
  "contact_person": "John Doe",
  "contact_phone": "+919876543210",
  "contact_email": "john@test.com",
  "allocated_vehicle_count": 2,
  "member_count": 3,
  "status": "Active"
}

###
@officeId = {{createOffice.response.body.data.id}}

### 14. Create office missing required field (expect 422)
POST {{baseUrl}}/admin/offices
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "block": "A"
}

### 15. Get single office
GET {{baseUrl}}/admin/offices/{{officeId}}
Authorization: Bearer {{adminToken}}

### 16. Update office
PUT {{baseUrl}}/admin/offices/{{officeId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "company_name": "Updated Resident",
  "status": "Active"
}

# ====================================================================
# USERS / SECURITY MANAGEMENT
# ====================================================================

### 17. List security users
GET {{baseUrl}}/admin/users
Authorization: Bearer {{adminToken}}

### 18. Create security user
# @name createSecurityUser
POST {{baseUrl}}/admin/users
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Test Security Guard",
  "email": "testguard@officegate.com",
  "phone": "+919876500001",
  "password": "Guard@123",
  "role": "security"
}

###
@secUserId = {{createSecurityUser.response.body.data.id}}

### 19. Create user with duplicate email (expect 409 or 422)
POST {{baseUrl}}/admin/users
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Duplicate",
  "email": "admin@officegate.com",
  "password": "Test@123",
  "role": "security"
}

### 20. Suspend user
PUT {{baseUrl}}/admin/users/{{secUserId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "inactive"
}

# ====================================================================
# VISITORS
# ====================================================================

### 21. List all visitors
GET {{baseUrl}}/admin/visitors
Authorization: Bearer {{adminToken}}

### 22. Create visitor entry (happy path)
