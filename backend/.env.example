APP_NAME=OfficeGate API
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

# Comma-separated frontend origins allowed by CORS.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Comma-separated reverse-proxy IPs/CIDRs allowed to supply X-Forwarded-For.
TRUSTED_PROXIES=

# Generate strong random values before production.
JWT_ACCESS_SECRET=dev-only-access-secret-replace-before-production-64-bytes
JWT_REFRESH_SECRET=dev-only-refresh-secret-replace-before-production-64-bytes
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# sqlite is ready for local dev. Use mysql in production.
DB_DRIVER=sqlite
DB_DATABASE=storage/database.sqlite

# MySQL example:
# DB_DRIVER=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=officegate
# DB_USERNAME=officegate
# DB_PASSWORD=

SEED_ADMIN_EMAIL=admin@officegate.com
SEED_ADMIN_PASSWORD=ChangeMe@12345
SEED_SECURITY_EMAIL=security@officegate.com
SEED_SECURITY_PASSWORD=ChangeMe@12345
SEED_TENANT_EMAIL=tenant@officegate.com
SEED_TENANT_PASSWORD=ChangeMe@12345

# Local OTP delivery logs codes to storage/logs/otp.log.
OTP_DRIVER=log
OTP_TTL_SECONDS=300
OTP_WEBHOOK_URL=
OTP_WEBHOOK_TOKEN=

# Razorpay Payment Gateway (P24)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here
# Use 'test' for sandbox, 'live' for production
RAZORPAY_MODE=test
