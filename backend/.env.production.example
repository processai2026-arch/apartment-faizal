APP_NAME=OfficeGate API
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.example.com
APP_TIMEZONE=Asia/Kolkata

CORS_ALLOWED_ORIGINS=https://officegate.example.com

# Set to your load balancer, reverse proxy, or CDN IP/CIDR list. Leave empty for direct Apache/PHP hosting.
TRUSTED_PROXIES=

# Replace these with two different random secrets of at least 64 characters.
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_CHAR_ACCESS_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_RANDOM_64_CHAR_REFRESH_SECRET
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=officegate
DB_USERNAME=officegate
DB_PASSWORD=REPLACE_WITH_STRONG_DATABASE_PASSWORD

SEED_ADMIN_EMAIL=admin@officegate.com
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_INITIAL_ADMIN_PASSWORD
SEED_SECURITY_EMAIL=security@officegate.com
SEED_SECURITY_PASSWORD=REPLACE_WITH_STRONG_INITIAL_SECURITY_PASSWORD
SEED_TENANT_EMAIL=tenant@officegate.com
SEED_TENANT_PASSWORD=REPLACE_WITH_STRONG_INITIAL_TENANT_PASSWORD

OTP_DRIVER=webhook
OTP_TTL_SECONDS=300
OTP_WEBHOOK_URL=https://sms-provider.example.com/send-otp
OTP_WEBHOOK_TOKEN=REPLACE_WITH_SMS_PROVIDER_TOKEN

# Required in production. Generate different random 32+ byte values for each QR scope.
SEED_GATE_VISITOR_ENTRY_TOKEN=REPLACE_WITH_RANDOM_VISITOR_ENTRY_TOKEN
SEED_GATE_VISITOR_CHECKOUT_TOKEN=REPLACE_WITH_RANDOM_VISITOR_CHECKOUT_TOKEN
SEED_GATE_VEHICLE_ENTRY_TOKEN=REPLACE_WITH_RANDOM_VEHICLE_ENTRY_TOKEN
SEED_GATE_VEHICLE_CHECKOUT_TOKEN=REPLACE_WITH_RANDOM_VEHICLE_CHECKOUT_TOKEN
